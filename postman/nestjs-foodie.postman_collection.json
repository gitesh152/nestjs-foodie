			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"packages": {},
						"requests": {},
						"exec": [
							""
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"packages": {},
						"requests": {},
						"exec": [
							"const res = pm.response.json();",
							"",
							"// ❌ If GraphQL returned errors → do nothing",
							"if (res.errors) {",
							"  console.warn(\"GraphQL Error:\", res.errors[0].message);",
							"  return;",
							"}",
							"",
							"// ✅ If no data → skip",
							"if (!res.data) return;",
							"",
							"// ✅ SIGNUP (if tokens returned)",
							"if (res.data.signup?.accessToken) {",
							"  pm.environment.set(\"accessToken\", res.data.signup.accessToken);",
							"  pm.environment.set(\"refreshToken\", res.data.signup.refreshToken);",
							"  console.log(\"Signup success → tokens saved\");",
							"}",
							"",
							"// ✅ LOGIN",
							"if (res.data.login?.accessToken) {",
							"  pm.environment.set(\"accessToken\", res.data.login.accessToken);",
							"  pm.environment.set(\"refreshToken\", res.data.login.refreshToken);",
							"  console.log(\"Login success → tokens saved\");",
							"}",
							"",
							"// ✅ REFRESH",
							"if (res.data.refresh?.accessToken) {",
							"  pm.environment.set(\"accessToken\", res.data.refresh.accessToken);",
							"  pm.environment.set(\"refreshToken\", res.data.refresh.refreshToken);",
							"  console.log(\"Refresh success → tokens saved\");",
							"}",
							"",
							"// ✅ LOGOUT",
							"if (res.data.logout) {",
							"  pm.environment.unset(\"accessToken\");",
							"  pm.environment.unset(\"refreshToken\");",
							"  console.log(\"Logged out → tokens cleared\");",
							"}",
							"",
							"// ✅ GLOBAL LOGOUT",
							"if (res.data.logoutAll) {",
							"  pm.environment.unset(\"accessToken\");",
							"  pm.environment.unset(\"refreshToken\");",
							"  console.log(\"Globally Logged out → tokens cleared\");",
							"}"
						]
					}
				}
			]
		},
